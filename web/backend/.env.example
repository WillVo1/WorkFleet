# Copy to .env and fill in. NEVER commit .env.
HAI_API_KEY=hk-...
# HAI_BASE_URL=            # leave unset for EU (SDK default)
GCP_ZONE=us-east4-a
TRYTOND_VM=trytond-server
MAX_STEPS=200

# Demo mode: rewind each worker's desktop to a clean baseline before every task
# so re-running a demo starts fresh (no window left open from the last run).
# Default off. Capture a baseline once per worker via POST /api/workers/{name}/baseline.
# DEMO_MODE=1
# DEMO_USER=agent                                  # desktop session user ($HOME to rewind)
# DEMO_BASELINE_PATH=/opt/agent/home-baseline.tgz  # pristine-home tarball (outside $HOME)
# DEMO_KILL_PROCESSES=slack,chrome,chromium,firefox,xterm,soffice
